{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    },
    "types": [
      "electron-vite/node"
    ]
  },
  "include": [
    "src/main",
    "src/lib",
    "src/ipc",
    "electron.vite.config.ts",
    "package.json",
    "types.d.ts",
  ]
}